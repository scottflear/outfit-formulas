# Outfit Formulas Email Worker — Environment Variables
# Copy to /home/ubuntu/outfit-formulas/of.env on Lightsail

# Supabase (OF project)
OF_SUPABASE_URL=CHANGE_ME
OF_SUPABASE_KEY=CHANGE_ME

# Claude (OF's own key — Sonnet 4.6)
OF_CLAUDE_API_KEY=CHANGE_ME

# AWS SES (shared account)
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
SES_REGION=CHANGE_ME
